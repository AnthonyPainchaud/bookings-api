{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=bookings;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "bookings-api",
    "Audience": "bookings-api-clients",
    "ExpiryMinutes": 60
  },
  "RateLimiting": {
    "GlobalPermitLimit": 100,
    "AuthPermitLimit": 5
  }
}
